{
  "mcpServers": {
    "supabase": {
      "command": "npx",
      "args": [
        "-y",
        "@supabase/mcp-server-supabase@latest",
        "--read-only",
        "--project-ref", "bfwohzcugtwbhhxdqgme"
      ],
      "env": {
        "SUPABASE_ACCESS_TOKEN": "REPLACE_WITH_YOUR_SBP_TOKEN"
      }
    }
  }
}
