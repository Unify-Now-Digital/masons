# Supabase Configuration
# Copy this file to .env and fill in your actual values
# Get these from your Supabase project settings: https://app.supabase.com/project/_/settings/api

VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Comma-separated list of admin emails (WhatsApp admin controls, Sentry monitoring page + sentry-proxy)
VITE_ADMIN_EMAIL=admin@example.com,manager@example.com

# Supabase secret ADMIN_EMAILS must mirror VITE_ADMIN_EMAIL (comma-separated) for sentry-proxy Edge Function

# Supabase Edge Functions (required for Stripe Checkout link + inbox features)
# Use your project URL: https://<PROJECT_REF>.supabase.co/functions/v1
VITE_SUPABASE_FUNCTIONS_URL=https://<PROJECT_REF>.supabase.co/functions/v1

# Inbox Admin Token (shared secret for edge functions: inbox-*, stripe-create-checkout-session)
# Must match Supabase secret INBOX_ADMIN_TOKEN
VITE_INBOX_ADMIN_TOKEN=your-inbox-admin-token

# Stripe publishable key (for embedded Payment Element)
# Get from Stripe Dashboard → API keys → Publishable key (pk_test_...)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key

# Restart Vite after changing any VITE_* env vars.

# --- Auth + per-user Gmail (see specs/supabase-auth-per-user-gmail-inbox-plan/quickstart.md) ---
# Supabase Dashboard → Auth → URL Configuration: add redirect URLs for both deployed domains:
#   https://mason.unifynow.digital/auth/callback
#   https://staging.unifynow.digital/auth/callback
# Supabase secrets for Gmail: GOOGLE_OAUTH_CLIENT_ID, GOOGLE_OAUTH_CLIENT_SECRET,
#   GMAIL_OAUTH_REDIRECT_URL = full URL of gmail-oauth-callback Edge Function
#     (e.g. https://<PROJECT_REF>.supabase.co/functions/v1/gmail-oauth-callback)
# Google Cloud Console → OAuth 2.0 Client → Authorized redirect URIs: add GMAIL_OAUTH_REDIRECT_URL exactly

# --- Supabase Edge Function secrets (set via: supabase secrets set KEY=value) ---
# INBOX_ADMIN_TOKEN          - same as VITE_INBOX_ADMIN_TOKEN
# INTERNAL_FUNCTION_KEY      - optional; for inbox-ai-suggest-reply when no login (localhost only)
# OPENAI_API_KEY             - OpenAI API key for inbox-ai-suggest-reply (server-side only)
# TWILIO_ACCOUNT_SID         - Twilio Account SID (for SMS inbox + WhatsApp)
# TWILIO_AUTH_TOKEN          - Twilio Auth Token
# TWILIO_PHONE_NUMBER        - Twilio phone number (E.164) for SMS/WhatsApp
# STRIPE_SECRET_KEY          - sk_test_... (Stripe test mode)
# STRIPE_WEBHOOK_SECRET      - whsec_... (from Stripe Dashboard → Webhooks)
# APP_ORIGIN                 - e.g. http://localhost:5173 (no trailing slash)
# SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY - usually pre-populated

# --- AI suggested reply (localhost without Supabase login) ---
# Use only for local dev until real auth exists. Do not commit keys.
# 1) supabase secrets set INTERNAL_FUNCTION_KEY=<your-secret>
# 2) supabase functions deploy inbox-ai-suggest-reply
# 3) In .env.local: VITE_INTERNAL_FUNCTION_KEY=<same-secret>
# Restart Vite after changing VITE_INTERNAL_FUNCTION_KEY.

# --- Twilio SMS Inbox ---
# Twilio Console → Phone Numbers → [your number] → Messaging:
#   Webhook URL: https://<PROJECT_REF>.supabase.co/functions/v1/twilio-sms-webhook
#   HTTP POST. Restart Vite after env changes.
