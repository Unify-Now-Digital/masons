      "id": "a8888888-8888-4888-8888-888888888888",
      "name": "GHL — Search Conversations",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        120,
        -160
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "ghlApiKey",
          "name": "ghlApiKey"
        }
      },
      "notes": "locationId is read from the n8n environment variable GHL_LOCATION_ID. Replace with $vars or a hard-coded value if you do not want to use env vars."
    },
    {
      "parameters": {
        "jsCode": "// === Inputs ===\nconst task = $('Loop Over Tasks').item.json;\nconst commentsItem = $('ClickUp — Get Task Comments').all();\nconst ghlContact = $('GHL — Get Contact').item.json || {};\nconst ghlConvs = $items('GHL — Search Conversations', 0, 0)[0]?.json || $('GHL — Search Conversations').item.json || {};\n\n// === Conversion check ===\nconst contact = ghlContact.contact || ghlContact;\nconst stageRaw = (\n  contact.pipelineStage ||\n  contact.pipeline_stage ||\n  contact.stage ||\n  contact.opportunityStage ||\n  ''\n).toString().toLowerCase();\nconst convertedKeywords = ['deposit paid', 'won', 'lost'];\nconst isConverted = convertedKeywords.some(k => stageRaw.includes(k));\n\n// === Inbound reply check ===\nconst taskCreatedTs = Number(task.date_created || 0);\nconst taskCreatedDate = new Date(taskCreatedTs);\nconst conversations = ghlConvs.conversations || ghlConvs.data || [];\nlet hasInboundReply = false;\nfor (const conv of conversations) {\n  const dir = (conv.lastMessageDirection || conv.lastOutboundMessageDirection || conv.direction || '').toString().toLowerCase();\n  const dateStr = conv.lastMessageDate || conv.dateUpdated || conv.dateAdded;\n  const lastDate = dateStr ? new Date(dateStr) : null;\n  if (dir.includes('inbound') && lastDate && lastDate > taskCreatedDate) {\n    hasInboundReply = true;\n    break;\n  }\n}\n\n// === Days since task created ===\nconst daysSince = taskCreatedTs\n  ? Math.floor((Date.now() - taskCreatedTs) / (1000 * 60 * 60 * 24))\n  : 0;\n\n// === Scan comments for prior follow-ups ===\nconst commentTexts = commentsItem\n  .flatMap(i => (i.json.comments || (Array.isArray(i.json) ? i.json : [i.json])))\n  .map(c => (c && (c.comment_text || c.text || c.comment)) || '')\n  .join(' \\n ');\nconst f1Sent = /Follow-up\\s*1\\s*sent/i.test(commentTexts);\nconst f2Sent = /Follow-up\\s*2\\s*sent/i.test(commentTexts);\nconst f3Sent = /Follow-up\\s*3\\s*sent/i.test(commentTexts);\n\n// === Decide action ===\nlet action = 'none';\nif (!isConverted && !hasInboundReply) {\n  if (daysSince >= 28 && !f3Sent) action = 'send_3';\n  else if (daysSince >= 14 && !f2Sent) action = 'send_2';\n  else if (daysSince >= 7 && !f1Sent) action = 'send_1';\n}\n\n// === Parse customer fields ===\nconst customFields = task.custom_fields || [];\nconst emailField = customFields.find(f => f.id === '6b7de2eb-ac4f-4880-b8d6-59bad0998df4');\nconst customerEmail = (emailField && emailField.value) || '';\n\nconst nameParts = (task.name || '').split(',').map(s => s.trim());\nconst orderRef = nameParts[0] || '';\nconst customerName = nameParts[1] || '';\nconst cemetery = nameParts[2] || '';\n\nreturn [{\n  json: {\n    action,\n    taskId: task.id,\n    customerEmail,\n    customerName,\n    cemetery,\n    orderRef,\n    daysSince,\n    isConverted,\n    hasInboundReply,\n    f1Sent,\n    f2Sent,\n    f3Sent,\n    pipelineStage: stageRaw\n  }\n}];\n"
      },
      "id": "a9999999-9999-4999-8999-999999999999",
      "name": "Evaluate Signals & Decide",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        340,
        -160
      ],
      "notes": "Pure logic node. Reads from upstream nodes by name (no extra fetches). Outputs the chosen action plus everything downstream nodes need."
